# Android builds must use a backend URL that the phone/emulator can reach.
# Emulator talking to backend on this PC:
# VITE_BACKEND_URL=http://10.0.2.2:3001
#
# Physical phone on the same Wi-Fi:
# VITE_BACKEND_URL=http://YOUR_PC_LAN_IP:3001
#
# Production:
# VITE_BACKEND_URL=https://your-api-domain.example
VITE_BACKEND_URL=https://your-api-domain.example
