rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isGamePlayer(gameId) {
      return isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.players);
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
      
      match /decks/{deckId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Games
    match /games/{gameId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated(); // Simplified for now, in production we'd check if player is in game
    }
  }
}
