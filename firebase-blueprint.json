{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "favoriteCardId": { "type": "string" }
      },
      "required": ["uid", "displayName"]
    },
    "Deck": {
      "title": "Deck",
      "description": "A player's card deck",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "cards": { "type": "array", "items": { "type": "string" } },
        "isFavorite": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "userId", "name", "cards"]
    },
    "Game": {
      "title": "Game",
      "description": "Active TCG match state",
      "type": "object",
      "properties": {
        "gameId": { "type": "string" },
        "status": { "type": "string", "enum": ["WAITING", "ACTIVE", "FINISHED"] },
        "players": { "type": "object" },
        "phase": { "type": "string" },
        "turnCount": { "type": "number" },
        "winnerUid": { "type": "string" },
        "logs": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number" }
      },
      "required": ["gameId", "status", "players"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/users/{userId}/decks/{deckId}": {
      "schema": "Deck",
      "description": "User's custom decks"
    },
    "/games/{gameId}": {
      "schema": "Game",
      "description": "Active game sessions"
    }
  }
}
